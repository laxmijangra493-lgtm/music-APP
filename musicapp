@st.cache_data(show_spinner=False)
def fetch_song(query: str) -> dict | None:
    """Return the single best YouTube audio result for a query (Full Audio)."""
    opts = {
        "quiet": True,
        "no_warnings": True,
        "format": "bestaudio/best",
        "noplaylist": True,
    }
    with yt_dlp.YoutubeDL(opts) as ydl:
        try:
            info = ydl.extract_info(f"ytsearch1:{query} audio", download=False)
            entries = info.get("entries") or []
            if not entries: return None
            entry = entries[0]
            if not entry: return None
            
            url = entry.get("url", "")
            if not url:
                for fmt in entry.get("formats", []):
                    if fmt.get("url"):
                        url = fmt["url"]
                        break
                        
            return {
                "title":     entry.get("title", "Unknown"),
                "url":       url,
                "thumbnail": entry.get("thumbnail", ""),
                "channel":   entry.get("uploader", "Unknown Artist"),
                "duration":  entry.get("duration", 0),
            }
        except Exception as e:
            return None

def fmt_dur(secs):
    if not secs: return ""
    m, s = divmod(int(secs), 60)
    return f"{m}:{s:02d}"

def truncate(text, length=50):
    return text if len(text) <= length else text[:length] + "…"

