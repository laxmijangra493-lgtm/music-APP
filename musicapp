<script>
(function setupAutoplay() {
    function attachEndedListener() {
        const audios = document.querySelectorAll('audio');
        audios.forEach(audio => {
            if (audio._apAttached) return;
            audio._apAttached = true;
            audio.addEventListener('ended', () => {
                const btns = Array.from(document.querySelectorAll('button'));
                // Look for Next button by standard label or custom key text
                const nextBtn = btns.find(b => b.innerText.trim().includes('⏭') || b.dataset.key === 'next_btn');
                if (nextBtn) nextBtn.click();
            });
        });
    }
    const interval = setInterval(attachEndedListener, 800);
    setTimeout(() => clearInterval(interval), 30000);
})();
</script>
""", unsafe_allow_html=True)


